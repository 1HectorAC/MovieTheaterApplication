@model List<MovieTheaterApplication.Models.ViewModels.ShowingSelectionViewModel>

@{
    ViewData["Title"] = "ShowingSelection";
}

<partial name="_ProgressIndicatorPartial" model=2></partial>
<hr />
<h4 style="text-align:center">Movie: @ViewBag.MovieTitle </h4>
<hr/>

<div class="centerPanelParent">
    <div>
        <div class="basicPanel">
            @foreach (var item in Model)
            {
                <div>
                    <a asp-controller="Home"
                       asp-action="SeatSelection"
                       asp-route-ShowingId="@item.Id"
                       class="btn btn-primary">
                        @item.ShowingTime
                    </a>
                </div>

            }
        </div>
    </div>
</div>
