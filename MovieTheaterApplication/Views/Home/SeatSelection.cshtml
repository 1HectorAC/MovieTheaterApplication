@model MovieTheaterApplication.Models.ViewModels.SeatSelectionViewModel

<partial name="_ProgressIndicatorPartial" model=3></partial>
<hr />
<h4 style="text-align:center">Movie: @Model.MovieTitle</h4>
<hr />
<h5 style="text-align:center">Date/Time: @Model.ShowingTime.ToString("g")</h5> 
<hr />

<div class="centerPanelParent">
    <div class="basicPanel2">
        @if(Model.TotalAvailableSeats > 0)
        {
            <form asp-controller="Home" asp-action="SelectShowingSeat" method="post">
                <input type="hidden" name="ShowingId" value=@Model.ShowingId />

                @foreach (var group in Model.GroupedSeats)
                {
                    <div class="row">
                        @foreach (var seat in group)
                        {
                            <div class="col-sm-4">
                                <div class="@(seat.IsSelected ? "seatStatusTaken" : "seatStatusNormal")">
                                    <label for="seat@(group.Key)@(seat.Column)">@group.Key @seat.Column</label>

                                    <input id="seat@(group.Key)@(seat.Column)"
                                           class="seatElement"
                                           name="SeatIds"
                                           type="checkbox"
                                           value="@seat.SeatId"
                                           disabled="@(seat.IsSelected)" />
                                </div>
                            </div>
                        }
                    </div>
                }
                <br />
                <button class="btn btn-primary submitButton" disabled>Submit</button>
                @if (TempData["ErrorMessage"] != null)
                {
                    <p>System Error. Can't select seats.</p>
                }
            </form>
            <p class="test"></p>
        }
        else
        {
            <div>
                <h1>No Seats Available</h1>
                <br /><br />
                <a asp-controller="Home"
                   asp-action="ShowingSelection"
                   asp-route-MovieId="@(Model.MovieId)"
                   class="btn btn-primary">Back to Showing Selction</a>
            </div>
            
        }

    </div>
</div>

<script>
        // Disable/Enable Submit button based on if any Seats Selected
        const seats = document.querySelectorAll(".seatElement");
        const submitButton = document.querySelector(".submitButton");
        seats.forEach(button => {
            button.addEventListener("click", event => {
                    if(button.checked){
                        submitButton.disabled = false;
                    }
                    else{
                        // Check all seats checkboxs to disable submit button
                        const allUnchecked = Array.from(seats).every(cb => !cb.checked);
                        if(allUnchecked)
                            submitButton.disabled = true;
                    }
            });
        });
</script>

